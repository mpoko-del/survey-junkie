<!-- Consent banner (simple) -->
<div class="sa-consent" id="saConsent" style="display:none;" role="dialog" aria-live="polite" aria-label="Cookie consent">
    <p>We use cookies and tracking to improve your experience and to serve ads. By clicking "Accept" you consent to tracking (including Facebook pixel). You can change this anytime in your browser storage.</p>
    <div class="actions">
        <button class="btn btn-decline" id="saDecline">Decline</button>
        <button class="btn btn-accept" id="saAccept">Accept</button>
    </div>
</div>

<script>
    (function(){
        var consent = localStorage.getItem('sa_tracking_consent');
        var banner = document.getElementById('saConsent');
        var accept = document.getElementById('saAccept');
        var decline = document.getElementById('saDecline');
        if(!consent){ banner.style.display = 'flex'; }
        if(consent === 'granted'){
            // already granted — load pixel
            if(typeof loadFbPixel === 'function') loadFbPixel();
        }
        accept && accept.addEventListener('click', function(){
            localStorage.setItem('sa_tracking_consent','granted');
            banner.style.display = 'none';
            if(typeof loadFbPixel === 'function') loadFbPixel();
        });
        decline && decline.addEventListener('click', function(){
            localStorage.setItem('sa_tracking_consent','denied');
            banner.style.display = 'none';
        });
    })();
</script>

